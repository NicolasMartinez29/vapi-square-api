# Square API credentials — get these from https://developer.squareup.com/apps
SQUARE_ACCESS_TOKEN=your_square_access_token_here
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=your_square_location_id_here

# Default team member (barber/staff) ID who will be assigned the booking
SQUARE_TEAM_MEMBER_ID=your_team_member_id_here

# Map service names (what Vapi collects) to Square catalog service variation IDs
# Format: JSON object, keys are lowercase service names, values are Square service variation IDs
# Example: {"haircut":"ABC123XYZ","beard trim":"DEF456UVW"}
SERVICE_VARIATION_MAP={"haircut":"REPLACE_WITH_SQUARE_SERVICE_VARIATION_ID"}

# Timezone for date/time parsing (IANA format)
TIMEZONE=America/Chicago

# Server port
PORT=3000
